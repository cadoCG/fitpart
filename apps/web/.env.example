# URL des CAD-Service (FastAPI). Lokal: docker compose oder uvicorn auf 8000.
CAD_SERVICE_URL=http://localhost:8000

# Shared-Secret zwischen Web-Proxy und CAD-Service (Härtung). Muss exakt dem
# CAD_SHARED_SECRET des Containers entsprechen. Leer lassen für lokales Dev.
# Auf Vercel als (nicht-sensitive ist ok, besser sensitive) Env-Var setzen.
CAD_SHARED_SECRET=

# Claude API für den Vision-Endpoint (/api/analyze).
# Empfehlung: dedizierter Key NUR für FitPart + Budget-Limit im Anthropic Console.
ANTHROPIC_API_KEY=

# Durable Tages-Quota für /api/analyze (Supabase, gegen Kosten-Missbrauch).
# Optional – Defaults: 15 pro IP/Tag, 300 global/Tag.
# ANALYZE_IP_DAILY_LIMIT=15
# ANALYZE_GLOBAL_DAILY_LIMIT=300

# Supabase (folgt mit Auth-Integration)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
